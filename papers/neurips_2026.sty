% NeurIPS 2026 style file (based on NeurIPS 2024 template)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/01 NeurIPS 2026 submission]

\newif\if@neuripsfinal\@neuripsfinalfalse
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripsfinalfalse}
\ProcessOptions\relax

% Page layout
\RequirePackage[letterpaper,
    textwidth=6.5in,
    textheight=9in,
    marginparwidth=0.7in,
    centering]{geometry}

% Font and spacing
\RequirePackage{times}
\linespread{1.0}
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{2ex plus 1ex minus .2ex}{1ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.8ex plus .2ex}

% Abstract
\renewenvironment{abstract}{%
    \centerline{\large\bfseries Abstract}%
    \vspace{0.5ex}%
    \begin{quote}\small
}{%
    \end{quote}%
    \vspace{1ex}%
}

% Author formatting
\if@neuripsfinal
    % Show author names in final version
\else
    % Anonymous submission
    \renewcommand{\author}[1]{}
    \renewcommand{\thanks}[1]{}
\fi

% Natbib compatibility
\RequirePackage{natbib}
\setcitestyle{authoryear,round,semicolon}

% Hyperref colors
\RequirePackage{xcolor}
\definecolor{linkcolor}{rgb}{0.0,0.3,0.6}

\AtBeginDocument{%
    \@ifpackageloaded{hyperref}{%
        \hypersetup{
            colorlinks=true,
            linkcolor=linkcolor,
            citecolor=linkcolor,
            urlcolor=linkcolor
        }
    }{}
}

% Running headers
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

\endinput
